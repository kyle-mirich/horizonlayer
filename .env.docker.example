DATABASE_URL=postgres://postgres:postgres@db:5432/horizon_layer
DB_HOST=db
DB_PORT=5432
DB_NAME=horizon_layer
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL_MODE=disable
DB_SSL_REJECT_UNAUTHORIZED=true
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000

EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

APP_NAME=Horizon Layer
APP_VERSION=1.0.0
SERVER_TRANSPORT=http
DEV_ROUTES_ENABLED=false
HOST=0.0.0.0
PORT=3000
APP_BASE_URL=http://127.0.0.1:3000
MCP_RESOURCE_PATH=/mcp
ALLOWED_HOSTS=
XDG_CACHE_HOME=/app/runtime-state/cache
HF_HOME=/app/runtime-state/hf

# Optional: override host/port bindings (docker-compose.yml reads these)
# APP_HOST=127.0.0.1
# APP_PORT=3000
# DB_HOST=127.0.0.1
# DB_PORT=5432
